# ─────────────────────────────────────────────────
# Supabase (public — préfixe NEXT_PUBLIC)
# Obtenir depuis : Supabase Dashboard → Settings → API
# ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ─────────────────────────────────────────────────
# Supabase (serveur uniquement — NE PAS préfixer NEXT_PUBLIC)
# ATTENTION : la service_role key bypasse le RLS — ne jamais exposer côté client
# ─────────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ─────────────────────────────────────────────────
# Cron secret — protège la route POST /api/cron/alertes
# Générer avec : openssl rand -hex 32
# Utiliser comme header : Authorization: Bearer <valeur>
# ─────────────────────────────────────────────────
CRON_SECRET=

# ─────────────────────────────────────────────────
# Cookie secret — signe le cookie __role (HMAC-SHA256)
# Générer avec : openssl rand -hex 32
# OBLIGATOIRE en production
# ─────────────────────────────────────────────────
COOKIE_SECRET=

# ─────────────────────────────────────────────────
# Google Gemini API (optionnel — pour fonctionnalités IA)
# ─────────────────────────────────────────────────
GEMINI_API_KEY=

APP_URL=http://localhost:3000
